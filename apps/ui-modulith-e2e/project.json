{
  "name": "ui-modulith-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/ui-modulith-e2e/src",
  "tags": ["scope:ui-modulith", "type:e2e"],
  "implicitDependencies": ["ui-modulith"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{projectRoot}/playwright-report", "{projectRoot}/test-results"],
      "options": {
        "config": "{projectRoot}/playwright.config.mts"
      },
      "configurations": {
        "ci": {
          "ci": true,
          "reporter": "line"
        }
      }
    }
  }
}
