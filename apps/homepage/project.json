{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "homepage",
  "projectType": "application",
  "sourceRoot": "apps/homepage/src",
  "tags": ["scope:homepage", "type:app"],
  "targets": {
    "dev-proxy": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "commands": ["pnpm nx run homepage:dev", "pnpm nx run blog:dev", "pnpm nx run todo:dev"]
      }
    },
    "preview-all": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build",
        { "projects": ["blog"], "target": "postbuild" },
        { "projects": ["todo"], "target": "build" }
      ],
      "options": {
        "cwd": "apps/homepage",
        "command": "node tools/preview.mjs"
      }
    },
    "typecheck": {
      "command": "tsc -p tsconfig.json",
      "options": { "cwd": "apps/homepage" },
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "i18n-check": {
      "command": "node ../../libs/i18n/check-parity.mjs src/locales",
      "options": { "cwd": "apps/homepage" },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/locales/en-US.json",
        "{projectRoot}/src/locales/pt-BR.json",
        "{workspaceRoot}/libs/i18n/check-parity.mjs"
      ]
    }
  }
}
