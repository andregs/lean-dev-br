{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "wanderlust-bff",
  "projectType": "application",
  "sourceRoot": "apps/wanderlust-bff/src",
  "tags": ["scope:wanderlust-bff", "type:app", "lang:java"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/wanderlust-bff",
        "command": "./mvnw -B -q clean package -DskipTests --no-transfer-progress"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/wanderlust-bff",
        "command": "./mvnw -B spring-boot:run --no-transfer-progress"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/wanderlust-bff",
        "command": "./mvnw -B test --no-transfer-progress"
      }
    },
    "native-build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/wanderlust-bff",
        "command": "./mvnw -B -Pnative native:compile --no-transfer-progress"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/wanderlust-bff",
        "command": "./mvnw -B -Pnative spring-boot:build-image -DskipTests --no-transfer-progress -Dspring-boot.build-image.imageName=${WANDERLUST_BFF_IMAGE:-wanderlust-bff:local} -Dspring-boot.build-image.env.BP_NATIVE_IMAGE_BUILD_ARGUMENTS=-J-Xmx5g"
      }
    },
    "test-integration": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/wanderlust-bff",
        "command": "./mvnw -B failsafe:integration-test failsafe:verify --no-transfer-progress"
      }
    },
    "docker-push": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/wanderlust-bff",
        "command": "docker push ${WANDERLUST_BFF_IMAGE:?set WANDERLUST_BFF_IMAGE to the registry image URL}"
      }
    }
  }
}
