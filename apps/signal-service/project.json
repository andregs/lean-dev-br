{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "signal-service",
  "projectType": "application",
  "sourceRoot": "apps/signal-service/src",
  "tags": ["scope:signal", "type:app", "lang:java"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/signal-service",
        "command": "./mvnw clean package -DskipTests"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/signal-service",
        "command": "./mvnw spring-boot:run"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/signal-service",
        "command": "./mvnw test"
      }
    },
    "native-build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/signal-service",
        "command": "./mvnw -Pnative native:compile"
      }
    }
  }
}
