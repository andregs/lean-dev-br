{
  "name": "blog",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/blog",
  "projectType": "application",
  "tags": ["scope:blog", "type:app"],
  "// targets": "to see all targets run: nx show project blog --web",
  "targets": {
    "content": {
      "executor": "nx:run-commands",
      "options": {
        "command": "velite build",
        "cwd": "apps/blog"
      },
      "cache": true,
      "inputs": ["{projectRoot}/content/**/*", "{projectRoot}/velite.config.ts"],
      "outputs": ["{projectRoot}/.velite"]
    },
    "build": {
      "dependsOn": ["content"]
    },
    "typecheck": {
      "dependsOn": ["content"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["content"],
      "options": {
        "cwd": "apps/blog",
        "parallel": true,
        "commands": ["velite dev", "next dev"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "apps/blog/vite.config.ts"
      }
    },
    "postbuild": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/blog",
        "command": "node tools/postbuild.mjs"
      },
      "cache": false
    },
    "preview": {
      "executor": "nx:run-commands",
      "dependsOn": ["postbuild"],
      "options": {
        "cwd": "apps/blog",
        "command": "node tools/preview.mjs"
      }
    }
  }
}
