{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "relay-service",
  "projectType": "application",
  "sourceRoot": "apps/relay-service/src",
  "tags": ["scope:relay", "type:app", "lang:java"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/relay-service",
        "command": "./mvnw clean package -DskipTests"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/relay-service",
        "command": "./mvnw spring-boot:run"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/relay-service",
        "command": "./mvnw test"
      }
    },
    "native-build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/relay-service",
        "command": "./mvnw -Pnative native:compile"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/relay-service",
        "command": "./mvnw -Pnative spring-boot:build-image -DskipTests --no-transfer-progress -Dspring-boot.build-image.imageName=${RELAY_IMAGE:-relay-service:local} -Dspring-boot.build-image.env.BP_NATIVE_IMAGE_BUILD_ARGUMENTS=-J-Xmx5g"
      }
    },
    "docker-push": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/relay-service",
        "command": "docker push ${RELAY_IMAGE:?set RELAY_IMAGE to the Artifact Registry image URL}"
      }
    }
  }
}
