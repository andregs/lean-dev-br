{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": [],
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@lean-dev-br/design-system/react": ["./libs/design-system/react/index.ts"],
      "@lean-dev-br/e2e-support": ["./libs/e2e-support/src/index.ts"],
      "@lean-dev-br/ui-modulith-kernel": ["./libs/ui-modulith/kernel/src/index.ts"],
      "@lean-dev-br/ui-modulith-catalog": ["./libs/ui-modulith/catalog/src/index.ts"],
      "@lean-dev-br/ui-modulith-cart": ["./libs/ui-modulith/cart/src/index.ts"],
      "@lean-dev-br/federation-kernel": ["./libs/federation/kernel/src/index.ts"],
      "@lean-dev-br/wanderlust-contracts": ["./libs/wanderlust-contracts/src/index.ts"]
    }
  }
}
