{
  "name": "kernel",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui-modulith/kernel/src",
  "projectType": "library",
  "tags": ["scope:ui-modulith", "type:kernel"],
  "// targets": "to see all targets run: nx show project kernel --web",
  "targets": {
    "openapi-types": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/src/api/openapi.yaml"],
      "outputs": ["{projectRoot}/src/api/schema.d.ts"],
      "options": {
        "command": "openapi-typescript {projectRoot}/src/api/openapi.yaml -o {projectRoot}/src/api/schema.d.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
