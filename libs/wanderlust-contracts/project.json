{
  "name": "wanderlust-contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/wanderlust-contracts/src",
  "projectType": "library",
  "tags": ["scope:wanderlust", "type:contracts"],
  "// targets": "to see all targets run: nx show project wanderlust-contracts --web",
  "targets": {
    "openapi-types": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/src/api/openapi.yaml"],
      "outputs": ["{projectRoot}/src/api/schema.d.ts"],
      "options": {
        "command": "openapi-typescript {projectRoot}/src/api/openapi.yaml -o {projectRoot}/src/api/schema.d.ts && prettier --write {projectRoot}/src/api/schema.d.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "openapi-types-check": {
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/src/api/openapi.yaml", "{projectRoot}/src/api/schema.d.ts"],
      "options": {
        "command": "openapi-typescript {projectRoot}/src/api/openapi.yaml -o {projectRoot}/src/api/schema.d.ts && prettier --write {projectRoot}/src/api/schema.d.ts && git diff --exit-code -- {projectRoot}/src/api/schema.d.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
